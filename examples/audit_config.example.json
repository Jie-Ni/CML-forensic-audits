{
  "input": "data/scored_traces.csv",
  "candidate_summary_output": "outputs/candidate_summary.csv",
  "decision_output": "outputs/decisions.csv",
  "group_columns": ["task", "scenario"],
  "required_columns": [
    "task",
    "scenario",
    "trace_id",
    "candidate_teacher",
    "suspect_logp",
    "reference_logp"
  ],
